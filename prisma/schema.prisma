// Unified Calendar — data model
// See plan: /Users/jonathanxu/.claude/plans/i-want-to-build-deep-volcano.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // SQLite — local dev uses ./dev.db; Fly prod stores at /app/data/dev.db on the mounted volume.
  provider = "sqlite"
}

// One connected source: Google, Notion, or Apple iCloud (CalDAV)
model Account {
  id          String    @id @default(cuid())
  source      String    // "google" | "notion" | "apple"
  label       String    // user-facing name, e.g. "personal@gmail.com"
  credentials String    // JSON, encrypted at rest with @noble/ciphers
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  calendars   Calendar[]

  @@unique([source, label])
}

// A calendar within an account: "Personal", "Work", a Notion DB, etc.
model Calendar {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceId  String  // remote id (Google calendarId, Notion DB id, CalDAV path)
  name      String
  color     String  // hex
  enabled   Boolean @default(true) // filter toggle
  isDefault Boolean @default(false) // where AI-scheduled events land
  config    String? // JSON: per-source config (e.g., Notion {dateProperty, titleProperty})
  // Top-level grouping in the FilterSidebar:
  //  - "scheduling" — synced calendars (Apple, Google) + manual scheduling
  //  - "tasks"      — local task subcategories (📋 Tasks, completed-tasks bucket, custom)
  section   String  @default("scheduling")
  events    Event[]

  @@unique([accountId, sourceId])
}

// A point/range on the calendar. May be an event, a Notion task with a date, or a deadline.
model Event {
  id         String   @id @default(cuid())
  calendarId String
  calendar   Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  sourceId   String   // remote id within the calendar
  title      String
  start      DateTime
  end        DateTime
  allDay     Boolean  @default(false)
  notes      String?
  kind       String   @default("event") // "event" | "task" | "deadline"
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  updatedAt  DateTime @updatedAt
  // raw payload from source for debugging / round-tripping
  raw        String?  // JSON

  // Recurrence (iCal-style) — null for non-recurring events
  rrule      String?  // e.g. "FREQ=WEEKLY;BYDAY=MO,WE,FR"
  // For recurring instances: pointer to the master event so we can find siblings
  recurrenceParentId String?
  recurrenceParent   Event?  @relation("RecurrenceChildren", fields: [recurrenceParentId], references: [id], onDelete: Cascade)
  recurrenceChildren Event[] @relation("RecurrenceChildren")

  // Push-notification bookkeeping — when did we last fire a "starts soon" reminder?
  notifiedAt DateTime?

  // When a task is checked off in TASK MODE, we move it into the Completed
  // calendar but remember its original calendar id here so unchecking can
  // move it back.
  completedFromCalendarId String?

  @@unique([calendarId, sourceId])
  @@index([start, end])
  @@index([notifiedAt, start])
}

// Long-term project. Often backed by a Notion page; has a due date.
model Project {
  id           String   @id @default(cuid())
  name         String
  dueDate      DateTime?
  notionPageId String?  @unique
  color        String   @default("#7c7c7c")
  notes        String?
  createdAt    DateTime @default(now())
  events       Event[]
  tasks        Task[]
}

// A unit of work, often pulled from a Notion task DB. May have a scheduled time.
model Task {
  id              String   @id @default(cuid())
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title           String
  dueDate         DateTime?
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  estimateMinutes Int?
  notionPageId    String?  @unique
  done            Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dueDate])
}

// Scheduling guidance Claude reads on every call: "no meetings before 10am", etc.
model Rule {
  id        String   @id @default(cuid())
  text      String
  priority  Int      @default(0) // higher = applied first when conflicts arise
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Conversation memory for the slot-it-in chat.
model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant" | "tool"
  content   String   // text content
  toolCalls String?  // JSON of tool_use blocks if assistant
  toolUseId String?  // when role = "tool", the tool_use_id this responds to
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Working hours and other singleton config. Single row keyed by id="settings".
model Settings {
  id                String  @id @default("settings")
  workdayStart      String  @default("09:00") // HH:mm
  workdayEnd        String  @default("18:00")
  timezone          String  @default("America/Toronto")
  defaultCalendarId String?
  passwordHash      String? // bcrypt-style hash for the local login shell
  encryptionKeySalt String? // for credential encryption

  // Push notifications
  remindersEnabled  Boolean @default(true)
  reminderLeadMin   Int     @default(15) // minutes before an event to notify
}

// Cron heartbeat — one row per job kind, updated on each successful tick.
// On startup the cron loop reads the last tick to detect (and replay) missed
// runs caused by Fly machine suspends/restarts.
model JobRun {
  kind        String   @id           // "reminders" | "backup"
  lastRunAt   DateTime
  lastError   String?
  updatedAt   DateTime @updatedAt
}

// Browser/device push subscription. One row per device that's opted in.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  label     String?  // user-friendly device name ("iPhone Safari", "MacBook Chrome")
  userAgent String?
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
}

// Weekly progress goals — schedule-driven, never touches tasks.
// "3 workouts per week", "4 hours of SHAI per week", "stretch every morning".
// The /progress page renders a weekly gantt of how much of each goal the
// user's actual schedule contains.
model ProgressGoal {
  id          String   @id @default(cuid())
  name        String   // "Fitness", "SHAI Research", "Stretching"
  color       String   @default("#7c7c7c")
  // count: count matching events per period
  // hours: sum the duration (in hours) of matching events per period
  // daily: at least one matching event per day (target = 7/week max)
  mode        String   @default("count")
  target      Float    @default(1)  // 3 workouts, 4 hours, 7 days, etc.
  period      String   @default("week") // "week" — only week is supported for now
  // Optional comma-separated list of Calendar.id values to match against
  matchCalendars String?
  // Optional comma-separated list of substrings to match against event titles
  // (case-insensitive). Any matches counts.
  matchTitles    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Standalone reminders — anything that isn't tied to a calendar event.
// Examples: "take vitamins at 9am", "submit timesheet every Friday at 5pm"
model Reminder {
  id        String   @id @default(cuid())
  title     String
  notes     String?
  dueAt     DateTime  // first occurrence
  rrule     String?   // for recurring reminders
  enabled   Boolean   @default(true)
  // Last fired-at (for de-duping in the cron loop). For recurring reminders, this advances.
  lastFiredAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([dueAt])
  @@index([lastFiredAt])
}
